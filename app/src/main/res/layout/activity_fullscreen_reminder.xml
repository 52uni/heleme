<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue_primary"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="40dp">

    <!-- GIF 动画区 -->
    <ImageView
        android:id="@+id/ivCheerGif"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:contentDescription="喝水鼓励动画"
        android:scaleType="fitCenter" />

    <!-- 提醒标题 -->
    <TextView
        android:id="@+id/tvReminderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="该喝水啦"
        android:textColor="@color/white"
        android:textSize="30sp"
        android:textStyle="bold"
        android:gravity="center" />

    <!-- 副标题 -->
    <TextView
        android:id="@+id/tvReminderAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="建议喝 200ml"
        android:textColor="#CCFFFFFF"
        android:textSize="18sp"
        android:gravity="center" />

    <!-- 达标鼓励文字 -->
    <TextView
        android:id="@+id/tvGoalCheer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text=""
        android:textColor="#FFEB3B"
        android:textSize="20sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- 喝一杯按钮 -->
    <TextView
        android:id="@+id/btnDrinkNow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_btn_drink_now"
        android:gravity="center"
        android:paddingHorizontal="56dp"
        android:paddingVertical="14dp"
        android:text="干杯！"
        android:textColor="@color/blue_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- 稍后再说 -->
    <TextView
        android:id="@+id/btnDismiss"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:padding="14dp"
        android:text="等一下下～"
        android:textColor="#99FFFFFF"
        android:textSize="16sp" />

</LinearLayout>
