<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WaterReminder" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#111111</item>
        <item name="colorPrimaryDark">#000000</item>
        <item name="colorAccent">#111111</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/screen_background</item>
    </style>

    <!-- 底部导航文字样式 -->
    <style name="BottomNavTextActive" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BottomNavTextInactive" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">11sp</item>
    </style>

    <!-- 底部导航选中指示器（透明，去除紫色背景） -->
    <style name="BottomNavIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@android:color/transparent</item>
    </style>

    <!-- 记录页 Tab 文字 -->
    <style name="RecordTabText" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <!-- 黑白风格 Chip -->
    <style name="BlackWhiteChip" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipBackgroundColor">@color/chip_bg_selector</item>
        <item name="chipStrokeColor">@color/chip_stroke_selector</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/chip_text_selector</item>
    </style>
</resources>
