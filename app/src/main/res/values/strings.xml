    <!-- 隐私说明 -->
    <string name="privacy_title">隐私与数据</string>
    <string name="privacy_subtitle">本地存储 · 零数据风险</string>
    <string name="privacy_intro">喝水提醒是一款完全离线运行的轻量应用。我们对您的隐私和数据安全负责：</string>
    <string name="privacy_item_1">所有数据仅保存在本机数据库中，绝不上传至任何服务器</string>
    <string name="privacy_item_2">不申请通讯录、相册、位置等无关权限</string>
    <string name="privacy_item_3">不接入任何第三方统计、追踪或广告 SDK</string>
    <string name="privacy_item_4">应用更新检查直接调用 Gitee / GitHub 官方 API，仅读取版本号</string>
    <string name="privacy_item_5">卸载应用即彻底清除全部数据，无残留</string>
    <string name="privacy_conclusion">您的喝水记录、人群设置、提醒时间，始终只属于您自己。</string>
    <string name="privacy_footnote">如有任何疑问，欢迎通过项目仓库反馈。</string>
</resources>
